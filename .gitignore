# Terraform state files
*.tfstate
*.tfstate.backup

# Terraform variable files (may contain sensitive values)
*.tfvars

# Terraform working directories
**/.terraform/

# Terraform lock file (optional: remove this line if you want to commit it)
# .terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Terraform plan files
*.tfplan

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform provider binaries
*.exe
*.zip

# OS files
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/
*.swp
*.swo
